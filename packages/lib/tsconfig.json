// IMPORT BOUNDARY: do NOT add `paths` entries that reach out of this repo
// (no `../<sibling>/*` aliases). `paths` is intentionally `{}`. See root
// tsconfig.json header for the full rationale.
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "paths": {}
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
